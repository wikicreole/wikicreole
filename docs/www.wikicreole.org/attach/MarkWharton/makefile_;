# Nmake macros for building Windows 32-Bit apps

!include <Win32.Mak>

all: $(OUTDIR) $(OUTDIR)\creole.exe

#----- If OUTDIR does not exist, then create directory
$(OUTDIR) :
    if not exist "$(OUTDIR)/$(NULL)" mkdir $(OUTDIR)

$(OUTDIR)\creole.obj: creole.c
    $(cc) $(cflags) $(cvars) /WX /Fo"$(OUTDIR)\\" /Fd"$(OUTDIR)\\" creole.c /DJAPAN /D_CRT_SECURE_NO_DEPRECATE

$(OUTDIR)\creole.exe: $(OUTDIR)\creole.obj
    $(link) $(conflags) -out:$(OUTDIR)\creole.exe $(OUTDIR)\creole.obj $(conlibs)

#--------------------- Clean Rule --------------------------------------------------------
# Rules for cleaning out those old files
clean:
        $(CLEANUP)
